---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";
import { blogCategories, categoryByKey } from "../../data/blogCategories";

const posts = (await getCollection("blog"))
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());

const visibleCategories = blogCategories
  .map((category) => ({
    ...category,
    count: posts.filter((post) => post.data.category === category.key).length,
  }))
  .filter((category) => category.count > 0);

const latestPosts = posts.slice(0, 9);
const featuredPost = latestPosts[0];
const secondaryPosts = latestPosts.slice(1, 4);
const remainingPosts = latestPosts.slice(4);

const formatDate = (date) =>
  date.toLocaleDateString("en-US", {
    timeZone: "UTC",
    month: "long",
    day: "numeric",
    year: "numeric",
  });
---
<BaseLayout
  title="Blog | Dongho Lee Real Estate"
  description="Ontario real estate market insights, buying and selling tips, rental guides, mortgage information, investment strategy, and newcomer settlement articles."
>
  <section class="blog-hero">
    <p class="page-kicker">Blog</p>
    <h1>Ontario Real Estate Insights</h1>
    <p>
      온타리오 부동산 시장 분석, 매매 팁, 임대 가이드, 투자 전략, 그리고 캐나다 생활 정보를
      데이터와 실제 상담 경험을 바탕으로 정리합니다.
    </p>
  </section>

  <nav class="blog-category-nav" aria-label="Blog categories">
    {visibleCategories.map((category) => (
      <a href={`/category/${category.slug}/`}>
        {category.label}
        <span>{category.count}</span>
      </a>
    ))}
  </nav>

  <section class="latest-posts" aria-label="Latest blog posts">
    <div class="section-row-heading">
      <div>
        <p class="page-kicker">Latest Posts</p>
        <h2>최근 등록 글</h2>
      </div>
      <span>{posts.length} posts</span>
    </div>

    {featuredPost && (
      <div class="latest-layout">
        <article class="featured-post-card">
          <p class="blog-meta">
            {formatDate(featuredPost.data.pubDate)} · {categoryByKey[featuredPost.data.category]?.label || featuredPost.data.category}
          </p>
          <h2>
            <a href={`/${featuredPost.slug}/`}>{featuredPost.data.title}</a>
          </h2>
          <p>{featuredPost.data.description}</p>
          <a class="text-link" href={`/${featuredPost.slug}/`}>Read More →</a>
        </article>

        <div class="latest-side-list">
          {secondaryPosts.map((post) => (
            <article>
              <p class="blog-meta">
                {formatDate(post.data.pubDate)} · {categoryByKey[post.data.category]?.label || post.data.category}
              </p>
              <h3>
                <a href={`/${post.slug}/`}>{post.data.title}</a>
              </h3>
            </article>
          ))}
        </div>
      </div>
    )}

    <div class="blog-card-grid">
      {remainingPosts.map((post) => (
        <article class="compact-post-card">
          <p class="blog-meta">
            {formatDate(post.data.pubDate)} · {categoryByKey[post.data.category]?.label || post.data.category}
          </p>
          <h3>
            <a href={`/${post.slug}/`}>{post.data.title}</a>
          </h3>
          <p>{post.data.description}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="category-overview" aria-label="Browse by category">
    <div class="section-row-heading">
      <div>
        <p class="page-kicker">Categories</p>
        <h2>카테고리별 보기</h2>
      </div>
    </div>

    <div class="category-overview-grid">
      {visibleCategories.map((category) => (
        <a class="category-overview-card" href={`/category/${category.slug}/`}>
          <span>{category.count} posts</span>
          <h3>{category.label}</h3>
          <p>{category.description}</p>
        </a>
      ))}
    </div>
  </section>
</BaseLayout>
