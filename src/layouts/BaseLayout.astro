---
const {
  title = "Dongho Lee Real Estate",
  description = "Toronto real estate blog and services.",
  canonical,
  image = "/uploads/2025/01/Dongho-The-realtor-Facebook-Cover.png",
  structuredData = [],
} = Astro.props;

const canonicalUrl =
  canonical ??
  new URL(Astro.url.pathname, Astro.site ?? Astro.url).toString();
const imageUrl = new URL(image, Astro.site ?? Astro.url).toString();
const structuredDataItems = Array.isArray(structuredData)
  ? structuredData
  : [structuredData];
const siteSchema = {
  "@context": "https://schema.org",
  "@type": "RealEstateAgent",
  "@id": new URL("/#realestateagent", Astro.site ?? Astro.url).toString(),
  name: "Dongho Lee 이동호",
  url: new URL("/", Astro.site ?? Astro.url).toString(),
  image: new URL("/uploads/2025/10/profile_dongholee.jpg", Astro.site ?? Astro.url).toString(),
  telephone: "+1-416-625-8241",
  email: "contact@donlee.realtor",
  identifier: "RECO registration no. 4773237",
  jobTitle: "Broker, REALTOR®",
  worksFor: {
    "@type": "RealEstateAgency",
    name: "HomeLife Frontier Realty Inc., Brokerage",
    telephone: "+1-416-218-8800",
    address: {
      "@type": "PostalAddress",
      streetAddress: "7620 Yonge St #400",
      addressLocality: "Thornhill",
      addressRegion: "ON",
      postalCode: "L4J 1V9",
      addressCountry: "CA",
    },
  },
  address: {
    "@type": "PostalAddress",
    streetAddress: "7620 Yonge St #400",
    addressLocality: "Thornhill",
    addressRegion: "ON",
    postalCode: "L4J 1V9",
    addressCountry: "CA",
  },
  areaServed: [
    "Toronto",
    "Greater Toronto Area",
    "North York",
    "Mississauga",
    "Oakville",
    "London Ontario",
    "Brantford",
  ],
  knowsLanguage: ["English", "Korean"],
  priceRange: "$$",
};

const currentPath = Astro.url.pathname;
const isActive = (href) =>
  href === "/" ? currentPath === "/" : currentPath.startsWith(href);

const gaMeasurementId = "G-H1TPFXTMXJ";
---
<!doctype html>
<html lang="ko">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Dongho Lee Real Estate" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={imageUrl} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={imageUrl} />
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="stylesheet" href="/styles/global.css?v=20260715-seo-analytics-layout" />
    <script async src={`https://www.googletagmanager.com/gtag/js?id=${gaMeasurementId}`}></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      window.gtag = gtag;
      gtag("js", new Date());
      gtag("config", "G-H1TPFXTMXJ", {
        linker: {
          domains: ["dongholee.ca", "donghotheagent.com"],
        },
      });
    </script>
    <script type="application/ld+json" set:html={JSON.stringify(siteSchema)} />
    {structuredDataItems.map((item) => (
      item && <script type="application/ld+json" set:html={JSON.stringify(item)} />
    ))}
  </head>
  <body>
    <header class="site-header">
      <div class="header-contact-strip">
        <div>
          <span>Broker, HomeLife Frontier Realty Inc., Brokerage</span>
          <a href="tel:4166258241">416-625-8241</a>
          <a href="mailto:contact@donlee.realtor">contact@donlee.realtor</a>
        </div>
      </div>
      <div class="header-inner">
        <a class="brand-lockup" href="/" aria-label="Dongho Lee Real Estate home">
          <img
            src="/uploads/2025/10/HomeLife-Modern-LOGO-Standard-no-background.png"
            alt="HomeLife Higher Standards"
          />
          <span>
            <strong>Dongho Lee</strong>
            <small>이동호 · Broker, REALTOR®</small>
          </span>
        </a>
        <nav class="nav">
          <a class:list={[{ active: isActive("/about/") }]} href="/about/">About</a>
          <a class:list={[{ active: isActive("/services/") }]} href="/services/">Services</a>
          <a class:list={[{ active: isActive("/blog/") || isActive("/category/") }]} href="/blog/">Blog</a>
          <a class:list={[{ active: isActive("/contact/") }]} href="/contact/">Contact</a>
        </nav>
        <a class="nav-cta" href="/contact/">상담 신청</a>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <footer class="site-footer">
      <div class="footer-inner">
        <div class="footer-brand">
          <img
            src="/uploads/2025/10/HomeLife-Modern-LOGO-Standard-no-background.png"
            alt="HomeLife Realty"
          />
          <strong>Dongho Lee</strong>
          <span>이동호 · Broker, REALTOR®</span>
          <span>HomeLife Frontier Realty Inc., Brokerage</span>
        </div>
        <div class="footer-link-groups">
          <nav aria-label="Quick links">
            <h2>Quick Links</h2>
            <a href="/about/">About Dongho Lee</a>
            <a href="/services/">Services</a>
            <a href="/blog/">Latest Articles</a>
            <a href="/contact/">Contact</a>
            <a href="https://dongholee.ca/" target="_blank" rel="noopener noreferrer">Dongho Lee Personal Site</a>
          </nav>
          <nav aria-label="Popular guides">
            <h2>Popular Guides</h2>
            <a href="/category/market/">Market Updates</a>
            <a href="/category/buying-selling/">Buying & Selling</a>
            <a href="/category/newcomer/">Newcomer Guides</a>
            <a href="/downsizing-when-to-start-retirement-60s/">Downsizing</a>
          </nav>
        </div>
        <div class="footer-contact">
          <h2>Contact</h2>
          <p><span>Mobile</span> <a href="tel:4166258241">416-625-8241</a></p>
          <p><span>Office</span> <a href="tel:4162188800">416-218-8800</a></p>
          <p><span>Fax</span> 416-218-8807</p>
          <p><span>Email</span> <a href="mailto:contact@donlee.realtor">contact@donlee.realtor</a></p>
          <p><span>Address</span> 7620 Yonge St #400, Thornhill, ON L4J 1V9</p>
          <p><span>RECO</span> Registration no. 4773237</p>
        </div>
        <nav class="legal-nav" aria-label="Legal navigation">
          <a href="/privacy-policy/">Privacy Policy</a>
          <a href="/terms-and-conditions/">Terms & Conditions</a>
          <a href="/cookie-policy/">Cookie Policy</a>
          <a href="/disclaimer/">Disclaimer</a>
          <a href="/consumer-information/">RECO Consumer Information</a>
        </nav>
        <p class="fineprint">&copy; 2026 Dongho Lee Real Estate. All Rights Reserved.</p>
      </div>
    </footer>

    <script is:inline>
      (() => {
        const sendEvent = (eventName, params = {}) => {
          if (typeof window.gtag !== "function") return;
          window.gtag("event", eventName, params);
        };

        document.addEventListener("click", (event) => {
          const link = event.target.closest("a[href]");
          if (!link) return;

          const href = link.getAttribute("href") || "";
          const linkText = link.textContent?.trim().replace(/\s+/g, " ") || "";

          if (href.startsWith("tel:")) {
            sendEvent("phone_click", {
              event_category: "lead",
              link_url: href,
              link_text: linkText,
            });
            return;
          }

          if (href.startsWith("mailto:")) {
            sendEvent("email_click", {
              event_category: "lead",
              link_url: href,
              link_text: linkText,
            });
            return;
          }

          const targetUrl = new URL(href, window.location.href);

          if (
            targetUrl.hostname === "dongholee.ca" &&
            targetUrl.hostname !== window.location.hostname
          ) {
            sendEvent("cross_site_navigation", {
              link_url: targetUrl.href,
              link_text: linkText,
              destination_domain: targetUrl.hostname,
            });
          }

          if (targetUrl.pathname === "/contact/") {
            sendEvent("contact_cta_click", {
              event_category: "lead",
              link_url: targetUrl.href,
              link_text: linkText,
              page_path: window.location.pathname,
            });
          }
        });
      })();
    </script>
  </body>
</html>
